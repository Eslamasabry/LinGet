{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LinGet",
  "version": "0.1.0",
  "identifier": "com.linget.manager",
  "build": {
    "beforeDevCommand": "cd ../ui && npm run dev -- --port 5174",
    "devUrl": "http://localhost:5174",
    "beforeBuildCommand": "cd ../ui && npm run build",
    "frontendDist": "../ui/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "LinGet Package Manager",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "deb",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/256x256.png"
    ]
  }
}
